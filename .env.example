# Copy this file to .env and fill in the real secrets for your environment.
# Generate APP_KEY after setup with: php artisan key:generate

APP_NAME=AIRecruitment
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@example.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AI_SERVICE_URL=http://127.0.0.1:8001
AI_SERVICE_TIMEOUT=120
AI_MATCHING_TIMEOUT=70

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

REVERB_APP_ID=kltn-local
REVERB_APP_KEY=kltn-local-key
REVERB_APP_SECRET=kltn-local-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MOMO_BASE_URL=https://test-payment.momo.vn
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_PARTNER_NAME=AIRecruitment
MOMO_STORE_ID=AIRecruitmentStore
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REQUEST_TYPE=captureWallet
MOMO_LANG=vi
MOMO_TIMEOUT=30
MOMO_REDIRECT_URL=http://127.0.0.1:8000/api/v1/payments/momo/return
MOMO_IPN_URL=http://127.0.0.1:8000/api/v1/payments/momo/ipn
MOMO_MIN_AMOUNT=1000
MOMO_PENDING_EXPIRE_MINUTES=15
MOMO_AUTO_COMPLETE_RETURN_LOCAL=true

VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://127.0.0.1:8000/api/v1/payments/vnpay/return
VNPAY_IPN_URL=http://127.0.0.1:8000/api/v1/payments/vnpay/ipn
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other
VNPAY_MIN_AMOUNT=1000
VNPAY_PENDING_EXPIRE_MINUTES=15
VNPAY_AUTO_COMPLETE_RETURN_LOCAL=true
