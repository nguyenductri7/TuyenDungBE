    {
      "name": "2. Recruiter Setup",
      "item": [
        {
          "name": "Recruiter - Create Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res?.data?.id) {",
                  "  pm.environment.set('cong_ty_id', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_ntd}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ten_cong_ty\": \"Công ty AI Test\",\n  \"ma_so_thue\": \"{{ma_so_thue}}\",\n  \"dia_chi\": \"Đà Nẵng\",\n  \"email\": \"company-ai@example.com\",\n  \"website\": \"https://example.com\",\n  \"quy_mo\": \"11-50\",\n  \"nganh_nghe_id\": {{nganh_nghe_id}}\n}"
            },
            "url": {
              "raw": "{{be_url}}/v1/nha-tuyen-dung/cong-ty",
