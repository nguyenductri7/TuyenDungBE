    {
      "name": "6. Chatbot Via BE",
      "item": [
        {
          "name": "Candidate - AI Chat Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res?.data?.id) {",
                  "  pm.environment.set('ai_chat_session_id', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_ung_vien}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"related_ho_so_id\": {{ho_so_id}},\n  \"related_tin_tuyen_dung_id\": {{tin_tuyen_dung_id}},\n  \"title\": \"Tư vấn nghề nghiệp cùng AI\"\n}"
            },
            "url": {
              "raw": "{{be_url}}/v1/ai-chat/sessions",
              "host": [
                "{{be_url}}"
              ],
              "path": [
                "v1",
                "ai-chat",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "Candidate - AI Chat Sessions List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_ung_vien}}"
              }
            ],
            "url": {
              "raw": "{{be_url}}/v1/ai-chat/sessions",
              "host": [
                "{{be_url}}"
              ],
              "path": [
                "v1",
                "ai-chat",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "Candidate - AI Chat Stream Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_ung_vien}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": {{ai_chat_session_id}},\n  \"message\": \"{{chat_message}}\"\n}"
            },
            "url": {
              "raw": "{{be_url}}/v1/ai-chat/messages/stream",
              "host": [
                "{{be_url}}"
              ],
              "path": [
                "v1",
                "ai-chat",
                "messages",
                "stream"
              ]
            },
            "description": "Luồng chính để test chatbot chuyên nghiệp theo SSE. Nếu dùng Ollama hoặc OpenAI, BE sẽ relay stream thật từ provider."
          }
        },
        {
          "name": "Candidate - AI Chat Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_ung_vien}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": {{ai_chat_session_id}},\n  \"message\": \"Vì sao hồ sơ của tôi chưa phù hợp hoàn toàn với job này?\"\n}"
            },
            "url": {
              "raw": "{{be_url}}/v1/ai-chat/messages",
              "host": [
                "{{be_url}}"
              ],
              "path": [
                "v1",
                "ai-chat",
                "messages"
              ]
            },
            "description": "Request non-stream để đối chiếu với bản stream hoặc test nhanh khi UI chưa hỗ trợ SSE."
          }
        },
        {
          "name": "Candidate - AI Chat Get Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_ung_vien}}"
              }
            ],
            "url": {
              "raw": "{{be_url}}/v1/ai-chat/sessions/{{ai_chat_session_id}}/messages",
              "host": [
                "{{be_url}}"
              ],
              "path": [
                "v1",
                "ai-chat",
                "sessions",
                "{{ai_chat_session_id}}",
                "messages"
              ]
            }
          }
        },
        {
          "name": "Candidate - AI Chat Update Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_ung_vien}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": 2,\n  \"summary\": \"Đã hoàn thành phiên tư vấn nghề nghiệp thử nghiệm.\"\n}"
            },
            "url": {
              "raw": "{{be_url}}/v1/ai-chat/sessions/{{ai_chat_session_id}}/status",
              "host": [
                "{{be_url}}"
              ],
              "path": [
                "v1",
                "ai-chat",
                "sessions",
                "{{ai_chat_session_id}}",
                "status"
              ]
            }
          }
        }
      ]
    }
